#!/usr/bin/env bash
# Nightshift Kit — Pre-commit hook
# Reads lint and type_check commands from .nightshift/config.yaml
# and runs them before every commit. If either fails, the commit is rejected.
#
# Install: cp .nightshift/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# See: BOOTSTRAP.md § "Install Pre-Commit Hook"

set -euo pipefail

CONFIG=".nightshift/config.yaml"

if [ ! -f "$CONFIG" ]; then
    echo "[nightshift pre-commit] No config.yaml found — skipping checks"
    exit 0
fi

# Simple YAML value extractor (handles: key: "value" and key: value)
extract_cmd() {
    local key="$1"
    local val
    val=$(grep -E "^\s*${key}:" "$CONFIG" | head -1 | sed 's/^[^:]*:\s*//' | sed 's/^"//' | sed 's/"$//' | xargs)
    echo "$val"
}

LINT_CMD=$(extract_cmd "lint")
TYPE_CHECK_CMD=$(extract_cmd "type_check")

FAILED=0

if [ -n "$LINT_CMD" ]; then
    echo "[nightshift pre-commit] Running lint: $LINT_CMD"
    if ! eval "$LINT_CMD"; then
        echo "[nightshift pre-commit] LINT FAILED — commit rejected"
        FAILED=1
    fi
fi

if [ -n "$TYPE_CHECK_CMD" ]; then
    echo "[nightshift pre-commit] Running type check: $TYPE_CHECK_CMD"
    if ! eval "$TYPE_CHECK_CMD"; then
        echo "[nightshift pre-commit] TYPE CHECK FAILED — commit rejected"
        FAILED=1
    fi
fi

if [ "$FAILED" -ne 0 ]; then
    echo "[nightshift pre-commit] Fix the above errors and try again."
    exit 1
fi

exit 0
